# Gmail SMTP (used for email notifications via nodemailer)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Resend (email signups and transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_SEGMENT_ID=your-resend-audience-id

# Gemini API (used by scripts/gen-cover.mjs and /api/gen-cover for AI cover generation)
GEMINI_API_KEY=your-gemini-api-key

